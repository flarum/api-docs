{
    "$schema": "https://typedoc.org/schema.json",
    "entryPoints": ["./src"],
    "entryPointStrategy": "expand",
    "tsconfig": "./tsconfig.json",
    "skipErrorChecking": true,

    "externalPattern": [
        "**/node_modules/**",
        "src/**/compat.*",
        "**/framework/core/**"
    ],
    "excludeExternals": true,
    "excludeReferences": true
}